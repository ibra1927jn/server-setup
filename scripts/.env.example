# =============================================================
# .env.example — Plantilla de credenciales para el proyecto "set up"
# Copia este archivo como .env y reemplaza los valores CHANGE_ME
# NUNCA commitear el .env con valores reales
# =============================================================

# Hetzner VPS
# IP o hostname del servidor VPS en Hetzner
VPS_HOST=CHANGE_ME
# Usuario SSH para conectarse al VPS (por defecto root)
VPS_USER=root
# Ruta absoluta a la llave SSH privada (dejar vacio para password auth)
VPS_SSH_KEY_PATH=

# n8n
# Email de la cuenta admin de n8n
N8N_EMAIL=CHANGE_ME
# Password de la cuenta admin de n8n
N8N_PASSWORD=CHANGE_ME
# API key para la REST API de n8n
N8N_API_KEY=CHANGE_ME

# Telegram
# Token del bot de Telegram (obtener de @BotFather)
TELEGRAM_BOT_TOKEN=CHANGE_ME
# Chat ID del chat/grupo donde el bot envia mensajes
TELEGRAM_CHAT_ID=CHANGE_ME

# OpenRouter
# API key de OpenRouter para modelos de IA
OPENROUTER_API_KEY=CHANGE_ME

# GitHub
# Personal Access Token de GitHub (permisos: repo, workflow)
GITHUB_PAT=CHANGE_ME
