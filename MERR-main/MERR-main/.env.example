# ============================================
# HarvestPro NZ — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to git.
# ============================================

# === REQUIRED ===
# Supabase project URL & anon key (from supabase.com dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your_anon_key_here

# === OPTIONAL ===
# Gemini API key for AI features (optional)
VITE_GEMINI_API_KEY=

# App version (auto-set by CI/CD)
VITE_APP_VERSION=9.1.0

# Analytics toggle (true/false)
VITE_ENABLE_ANALYTICS=false

# Log level: debug | info | warn | error
VITE_LOG_LEVEL=info

# Feature flags (true/false)
# VITE_FEATURE_DARK_MODE=false
# VITE_FEATURE_PUSH_NOTIFICATIONS=false
